---
import Base from '../layouts/Base.astro';
import fs from 'fs';
import path from 'path';

const graphData = JSON.parse(
  fs.readFileSync(path.join(process.env.HOME, 'wiki', 'graph.json'), 'utf8')
);

const wikiDir = path.join(process.env.HOME, 'wiki');
const searchIndex = {};
for (const node of graphData.nodes) {
  const filePath = path.join(wikiDir, `${node.id}.md`);
  if (fs.existsSync(filePath)) {
    const raw = fs.readFileSync(filePath, 'utf8');
    // Strip frontmatter
    const body = raw.replace(/^---[\s\S]*?---\n/, '');
    searchIndex[node.id] = body.toLowerCase();
  }
}
---

<Base>
  <script id="graph-data" type="application/json" set:html={JSON.stringify(graphData)}></script>
  <script id="search-index" type="application/json" set:html={JSON.stringify(searchIndex).replace(/</g, '\\u003c').replace(/>/g, '\\u003e')}></script>

  <div id="app">
    <div id="topbar">
      <span id="brand">OPEN BRAIN</span>
      <div id="search-wrap">
        <span id="search-icon">⌕</span>
        <input id="search" type="text" placeholder="search topics..." autocomplete="off" spellcheck="false" />
      </div>
      <span id="topic-count">{graphData.nodes.length} topics</span>
    </div>

    <div id="panes">
      <div id="graph-pane">
        <div id="graph"></div>
        <div id="hover-label"></div>
        <div id="zoom-controls">
          <button id="zoom-in" aria-label="Zoom in">+</button>
          <button id="zoom-out" aria-label="Zoom out">−</button>
        </div>
        <div id="legend">
          <div class="legend-row"><span class="leg-solid"></span>shared entries</div>
          <button id="toggle-mentions" class="legend-row legend-toggle" title="Show/hide content mention edges">
            <span class="leg-dashed"></span>content mention
          </button>
        </div>
      </div>

      <div id="divider"></div>

      <div id="content-pane">
        <div id="content-empty">Click a node to explore a topic</div>
        <div id="content-loaded" hidden>
          <div id="content-header">
            <h1 id="content-title"></h1>
            <span id="content-meta"></span>
          </div>
          <div id="content-chips"></div>
          <div id="content-markdown"></div>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  #app { display: flex; flex-direction: column; height: 100vh; }

  /* ── Top bar ─────────────────────────────────────────── */
  #topbar {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 16px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--bg-surface);
    flex-shrink: 0;
  }
  #brand {
    color: var(--accent); font-size: 11px;
    letter-spacing: 2px; font-weight: 700; font-family: monospace;
  }
  #search-wrap {
    flex: 1; max-width: 380px;
    display: flex; align-items: center; gap: 8px;
    background: var(--bg-primary);
    border: 1px solid var(--bg-surface); border-radius: 4px;
    padding: 5px 10px;
  }
  #search-icon { color: var(--accent); opacity: 0.6; font-size: 15px; }
  #search {
    flex: 1; background: none; border: none; outline: none;
    color: var(--text-primary); font-size: 13px;
  }
  #search::placeholder { color: var(--text-muted); }
  #topic-count { color: var(--text-muted); font-size: 11px; font-family: monospace; margin-left: auto; }

  /* ── Panes ───────────────────────────────────────────── */
  #panes { display: flex; flex: 1; overflow: hidden; }

  #graph-pane {
    width: 52%; min-width: 200px; position: relative;
    flex-shrink: 0;
  }
  #divider {
    width: 5px; flex-shrink: 0; cursor: col-resize;
    background: var(--bg-surface);
    transition: background 0.15s;
  }
  #divider:hover, #divider.dragging { background: var(--accent); }
  #graph { width: 100%; height: 100%; }

  /* ── Zoom controls ───────────────────────────────────── */
  #zoom-controls {
    position: absolute; bottom: 14px; left: 14px;
    display: flex; flex-direction: column; gap: 4px;
  }
  #zoom-controls button {
    background: var(--bg-secondary); border: 1px solid var(--bg-surface);
    color: var(--accent); width: 28px; height: 28px;
    border-radius: 4px; cursor: pointer; font-size: 18px; line-height: 1;
    display: flex; align-items: center; justify-content: center;
  }
  #zoom-controls button:hover { background: var(--bg-surface); }

  /* ── Legend ──────────────────────────────────────────── */
  #legend {
    position: absolute; bottom: 14px; right: 14px;
    background: var(--bg-secondary); border: 1px solid var(--bg-surface);
    border-radius: 4px; padding: 7px 10px;
    display: flex; flex-direction: column; gap: 5px;
  }
  .legend-row {
    display: flex; align-items: center; gap: 8px;
    font-size: 10px; color: var(--text-muted); font-family: monospace;
  }
  .leg-solid {
    display: block; width: 22px; height: 2px;
    background: var(--accent); opacity: 0.5; border-radius: 1px;
  }
  #hover-label {
    position: absolute; pointer-events: none; display: none; z-index: 10;
    background: var(--bg-secondary); border: 1px solid var(--bg-surface);
    border-radius: 4px; padding: 4px 9px;
    font-size: 11px; color: var(--text-primary); font-family: monospace;
    white-space: nowrap;
  }
  .legend-toggle {
    background: none; border: none; cursor: pointer;
    padding: 2px 4px; border-radius: 3px;
    opacity: 0.4;
    transition: opacity 0.15s, background 0.15s;
  }
  .legend-toggle:hover { background: var(--bg-surface); opacity: 0.7; }
  .legend-toggle.active { opacity: 1; }

  .leg-dashed {
    display: block; width: 22px; height: 1px;
    background: repeating-linear-gradient(
      to right, #0d9488 0, #0d9488 4px, transparent 4px, transparent 7px
    );
    opacity: 0.7;
  }

  /* ── Content pane ────────────────────────────────────── */
  #content-pane {
    flex: 1; display: flex; flex-direction: column;
    overflow: hidden; background: var(--bg-secondary);
  }
  #content-empty {
    flex: 1; display: flex; align-items: center; justify-content: center;
    color: var(--text-muted); font-size: 13px;
  }
  #content-loaded {
    display: flex; flex-direction: column; height: 100%; overflow: hidden;
  }
  #content-loaded[hidden] { display: none; }
  #content-header {
    padding: 14px 28px 10px;
    border-bottom: 1px solid var(--bg-surface);
    background: var(--bg-primary); flex-shrink: 0;
  }
  #content-title {
    font-size: 18px; font-weight: 700;
    color: var(--text-primary); margin-bottom: 4px;
  }
  #content-meta { font-size: 11px; color: var(--accent); opacity: 0.7; font-family: monospace; }
  #content-chips {
    padding: 8px 28px; border-bottom: 1px solid var(--bg-surface);
    display: flex; flex-wrap: wrap; gap: 6px; flex-shrink: 0;
    min-height: 38px; align-items: center;
  }
  .chip {
    font-size: 11px; color: var(--accent-light);
    background: var(--accent-dim); border: 1px solid #1a4a46;
    padding: 3px 10px; border-radius: 20px;
    cursor: pointer; font-family: monospace;
    transition: background 0.12s;
  }
  .chip:hover { background: #1a5e58; }

  /* ── Markdown body ───────────────────────────────────── */
  #content-markdown {
    flex: 1; overflow-y: auto;
    padding: 16px 28px 16px 28px; line-height: 1.75;
    color: var(--text-secondary); font-size: 13px;
  }
</style>

<style is:global>
  /* All #content-markdown descendant rules must be global — content is injected via innerHTML
     and doesn't receive Astro's scoping attribute */
  #content-markdown h1 { display: none; }
  #content-markdown h2 {
    color: var(--text-primary); font-size: 20px; font-weight: 700;
    margin: 28px 0 4px; padding-top: 0;
    letter-spacing: -0.2px;
  }
  #content-markdown h3 {
    color: var(--accent-light); font-size: 16px; font-weight: 600;
    margin: 16px 0 4px; padding-top: 0;
  }
  #content-markdown p { margin-bottom: 6px; }
  #content-markdown strong { color: var(--text-primary); }
  #content-markdown em { color: var(--text-muted); }
  #content-markdown ul, #content-markdown ol { padding-left: 20px; margin-bottom: 10px; }
  #content-markdown li { margin-bottom: 4px; }
  #content-markdown code {
    background: var(--bg-surface); padding: 1px 5px; border-radius: 3px;
    font-family: monospace; font-size: 12px; color: var(--accent-light);
  }
  #content-markdown table { border-collapse: collapse; width: 100%; margin-bottom: 10px; }
  #content-markdown th, #content-markdown td { padding: 3px 28px 3px 0; text-align: left; vertical-align: top; }
  #content-markdown th { color: var(--text-muted); font-weight: 600; font-size: 12px; padding-bottom: 4px; }
  #content-markdown blockquote {
    border-left: 3px solid var(--accent-dim); padding-left: 12px;
    margin: 8px 0; color: var(--text-muted); font-style: italic;
  }
  #content-markdown hr {
    border: none;
    border-top: 1px solid #1e293b;
    margin: 20px 0 6px;
    height: 0;
  }
</style>

<script>
  import ForceGraph from 'force-graph';
  import { marked } from 'marked';
  import { zoomTransform } from 'd3-zoom';

  // ── Data ──────────────────────────────────────────────────────────────
  const graphData = JSON.parse(document.getElementById('graph-data').textContent);
  const nodeMap = Object.fromEntries(graphData.nodes.map(n => [n.id, n]));
  const searchIndex = JSON.parse(document.getElementById('search-index').textContent);

  function edgeSrc(e) { return typeof e.source === 'object' ? e.source.id : e.source; }
  function edgeTgt(e) { return typeof e.target === 'object' ? e.target.id : e.target; }

  // ── State ──────────────────────────────────────────────────────────────
  let selectedId = null;
  let hoveredId = null;
  let Graph = null;
  let showMentions = false;
  let searchTerm = '';

  // ── Node helpers ───────────────────────────────────────────────────────
  function nodeR(n) {
    return Math.min(14, Math.max(6, Math.sqrt(n.entries) * 2));
  }
  function nodeVal(n) {
    return (nodeR(n) / 4) ** 2;
  }

  function nodeColor(n) {
    const activeId = hoveredId || selectedId;
    if (n.id === selectedId) return '#2dd4bf';
    if (n.id === hoveredId) return '#2dd4bf';
    if (activeId) {
      const connected = graphData.edges.some(
        e => (edgeSrc(e) === activeId && edgeTgt(e) === n.id) ||
             (edgeTgt(e) === activeId && edgeSrc(e) === n.id)
      );
      return connected ? '#5eead4' : '#134e4a';
    }
    return '#5eead4';
  }

  // ── Direct hit detection — bypasses force-graph's shadow canvas ────────
  // force-graph's shadow canvas approach is unreliable: it only refreshes
  // every 800ms, and nodePointerAreaPaint circles can overlap at low zoom,
  // making many nodes invisible to hit detection. Instead we convert screen
  // coords to graph coords via d3-zoom's transform (stored on the canvas
  // element as __zoom) and check distance to each node directly.
  const container = document.getElementById('graph');

  function nodeAtPointer(clientX, clientY) {
    const canvas = container.querySelector('canvas');
    if (!canvas) return null;
    const t = zoomTransform(canvas);
    const rect = canvas.getBoundingClientRect();
    const gx = (clientX - rect.left - t.x) / t.k;
    const gy = (clientY - rect.top  - t.y) / t.k;
    let best = null, bestDist = Infinity;
    for (const n of graphData.nodes) {
      if (n.x == null) continue;
      const hitR = Math.max(nodeR(n) + 4, 12 / t.k);
      const d = Math.hypot(n.x - gx, n.y - gy);
      if (d <= hitR && d < bestDist) { best = n; bestDist = d; }
    }
    return best;
  }

  // ── Graph init ─────────────────────────────────────────────────────────
  Graph = ForceGraph()(container)
    .graphData({ nodes: graphData.nodes, links: graphData.edges })
    .nodeId('id')
    .nodeVal(nodeVal)
    .nodeLabel('')
    .nodeColor(nodeColor)
    .nodeCanvasObjectMode(() => 'replace')
    .nodeCanvasObject((n, ctx, globalScale) => {
      const r = nodeR(n);
      const activeId = hoveredId || selectedId;

      if (n.id === selectedId || n.id === hoveredId) {
        ctx.beginPath();
        ctx.arc(n.x, n.y, r + 8, 0, 2 * Math.PI);
        ctx.fillStyle = 'rgba(45,212,191,0.07)';
        ctx.fill();
        ctx.beginPath();
        ctx.arc(n.x, n.y, r + 4, 0, 2 * Math.PI);
        ctx.fillStyle = 'rgba(45,212,191,0.13)';
        ctx.fill();
      }

      ctx.beginPath();
      ctx.arc(n.x, n.y, r, 0, 2 * Math.PI);
      ctx.fillStyle = nodeColor(n);
      ctx.fill();

      const fontSize = 10 / globalScale;
      ctx.font = `${fontSize}px monospace`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'top';

      let labelColor = '#94a3b8';
      let labelAlpha = 1;
      if (n.id === selectedId || n.id === hoveredId) {
        labelColor = '#2dd4bf';
      } else if (activeId) {
        const connected = graphData.edges.some(
          e => (edgeSrc(e) === activeId && edgeTgt(e) === n.id) ||
               (edgeTgt(e) === activeId && edgeSrc(e) === n.id)
        );
        if (connected) { labelColor = '#5eead4'; }
        else { labelAlpha = 0.25; }
      }

      ctx.globalAlpha = labelAlpha;
      ctx.fillStyle = labelColor;
      ctx.fillText(n.label, n.x, n.y + r + 2);
      ctx.globalAlpha = 1;
    })
    .linkSource('source')
    .linkTarget('target')
    .linkWidth(l => l.type === 'shared_entries' ? Math.min(l.strength * 0.4 + 1, 3.5) : 0.5)
    .linkColor(l => l.type === 'shared_entries'
      ? 'rgba(45,212,191,0.35)'
      : 'rgba(13,148,136,0.25)')
    .linkCanvasObjectMode(l => l.type === 'content_mention' ? 'replace' : undefined)
    .linkCanvasObject((l, ctx) => {
      const src = l.source;
      const tgt = l.target;
      if (typeof src !== 'object' || typeof tgt !== 'object') return;
      ctx.beginPath();
      ctx.setLineDash([4, 3]);
      ctx.strokeStyle = 'rgba(13,148,136,0.25)';
      ctx.lineWidth = 0.5;
      ctx.moveTo(src.x, src.y);
      ctx.lineTo(tgt.x, tgt.y);
      ctx.stroke();
      ctx.setLineDash([]);
    })
    .linkVisibility(l => showMentions || l.type !== 'content_mention')
    .backgroundColor('#0a0e1a')
    .width(container.offsetWidth)
    .height(container.offsetHeight)
    .enableNodeDrag(false)
    .onBackgroundClick(() => {
      graphData.nodes.forEach(n => { delete n.fx; delete n.fy; });
      Graph.d3ReheatSimulation();
    });

  Graph.d3Force('charge').strength(-120);
  Graph.d3AlphaDecay(0.01);
  Graph.d3VelocityDecay(0.2);

  Graph.d3Force('gravity', alpha => {
    graphData.nodes.forEach(n => {
      n.vx -= n.x * 0.04 * alpha;
      n.vy -= n.y * 0.04 * alpha;
    });
  });

  Graph.d3ReheatSimulation();

  // ── Direct canvas interaction (hover + drag + click) ───────────────────
  const canvas = container.querySelector('canvas');
  let dragNode = null;
  let isDragging = false;
  const hoverLabel = document.getElementById('hover-label');

  canvas.addEventListener('mousedown', e => {
    if (e.button !== 0) return;
    const node = nodeAtPointer(e.clientX, e.clientY);
    if (node) {
      e.stopPropagation();
      dragNode = node;
      isDragging = false;
      node.fx = node.x;
      node.fy = node.y;
      hoverLabel.style.display = 'none';
      Graph.d3ReheatSimulation();
    }
  }, true);

  canvas.addEventListener('mousemove', e => {
    if (dragNode) {
      isDragging = true;
      const t = zoomTransform(canvas);
      const rect = canvas.getBoundingClientRect();
      dragNode.fx = (e.clientX - rect.left - t.x) / t.k;
      dragNode.fy = (e.clientY - rect.top  - t.y) / t.k;
    } else {
      const node = nodeAtPointer(e.clientX, e.clientY);
      const newId = node ? node.id : null;
      if (newId !== hoveredId) {
        hoveredId = newId;
        Graph.nodeColor(nodeColor);
        if (node) {
          hoverLabel.textContent = `${node.label} (${node.entries} entries)`;
          hoverLabel.style.display = 'block';
        } else {
          hoverLabel.style.display = 'none';
        }
      }
      if (hoverLabel.style.display !== 'none') {
        const rect = container.getBoundingClientRect();
        hoverLabel.style.left = (e.clientX - rect.left + 14) + 'px';
        hoverLabel.style.top  = (e.clientY - rect.top  - 10) + 'px';
      }
    }
  });

  canvas.addEventListener('mouseup', e => {
    if (e.button !== 0) return;
    if (dragNode) {
      if (!isDragging) selectTopic(dragNode.id);
      dragNode = null;
      isDragging = false;
    }
  });

  canvas.addEventListener('mouseleave', () => {
    if (dragNode) { dragNode = null; isDragging = false; }
    hoveredId = null;
    Graph.nodeColor(nodeColor);
    hoverLabel.style.display = 'none';
  });

  // Toggle content mention edges
  const toggleBtn = document.getElementById('toggle-mentions');
  toggleBtn.addEventListener('click', () => {
    showMentions = !showMentions;
    toggleBtn.classList.toggle('active', showMentions);
    Graph.linkVisibility(l => {
      if (!showMentions && l.type === 'content_mention') return false;
      if (searchTerm) return edgeSrc(l).includes(searchTerm) || edgeTgt(l).includes(searchTerm);
      return true;
    });
  });

  // Zoom buttons
  document.getElementById('zoom-in').addEventListener('click', () => {
    Graph.zoom(Graph.zoom() * 1.3, 300);
  });
  document.getElementById('zoom-out').addEventListener('click', () => {
    Graph.zoom(Graph.zoom() / 1.3, 300);
  });

  // Resize canvas when window resizes
  window.addEventListener('resize', () => {
    Graph.width(container.offsetWidth).height(container.offsetHeight);
  });

  // ── Topic selection ────────────────────────────────────────────────────
  async function selectTopic(id) {
    selectedId = id;
    Graph.nodeColor(nodeColor); // reassigning triggers redraw
    const url = new URL(window.location.href);
    url.searchParams.set('topic', id);
    window.history.pushState({}, '', url);
    await loadContent(id);
  }

  // ── Content panel ──────────────────────────────────────────────────────
  async function loadContent(id) {
    const res = await fetch(`/wiki/${id}.md`);
    if (!res.ok) return;
    const text = await res.text();

    // Parse frontmatter
    const fmMatch = text.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
    const meta = {};
    let body = text;
    if (fmMatch) {
      for (const line of fmMatch[1].split('\n')) {
        const idx = line.indexOf(': ');
        if (idx > 0) meta[line.slice(0, idx).trim()] = line.slice(idx + 2).trim();
      }
      body = fmMatch[2];
    }

    document.getElementById('content-title').textContent = meta.topic || id;
    document.getElementById('content-meta').textContent =
      `${meta.entries || '?'} entries · compiled ${meta.compiled || '?'}`;

    // Related chips: all directly connected topics
    const related = graphData.edges
      .filter(e => edgeSrc(e) === id || edgeTgt(e) === id)
      .map(e => edgeSrc(e) === id ? edgeTgt(e) : edgeSrc(e))
      .filter((v, i, a) => a.indexOf(v) === i)
      .sort();

    const chipsEl = document.getElementById('content-chips');
    chipsEl.innerHTML = related
      .map(r => `<button class="chip" data-topic="${r}">${nodeMap[r]?.label || r}</button>`)
      .join('');
    chipsEl.querySelectorAll('.chip').forEach(btn =>
      btn.addEventListener('click', () => selectTopic(btn.dataset.topic))
    );

    document.getElementById('content-markdown').innerHTML = marked.parse(body);
    document.getElementById('content-empty').style.display = 'none';
    document.getElementById('content-loaded').removeAttribute('hidden');
  }

  // ── Search ──────────────────────────────────────────────────────────────
  document.getElementById('search').addEventListener('input', e => {
    searchTerm = e.target.value.toLowerCase().trim();
    Graph.nodeVisibility(n =>
      !searchTerm ||
      n.id.includes(searchTerm) ||
      n.label.toLowerCase().includes(searchTerm) ||
      (searchIndex[n.id] && searchIndex[n.id].includes(searchTerm))
    );
    Graph.linkVisibility(l => {
      if (!showMentions && l.type === 'content_mention') return false;
      if (searchTerm) return edgeSrc(l).includes(searchTerm) || edgeTgt(l).includes(searchTerm);
      return true;
    });
  });

  // ── Draggable divider ──────────────────────────────────────────────────
  const divider = document.getElementById('divider');
  const graphPane = document.getElementById('graph-pane');
  const panesEl = document.getElementById('panes');

  divider.addEventListener('mousedown', e => {
    e.preventDefault();
    divider.classList.add('dragging');
    const onMove = ev => {
      const rect = panesEl.getBoundingClientRect();
      const newW = Math.min(Math.max(ev.clientX - rect.left, 200), rect.width - 200);
      graphPane.style.width = newW + 'px';
      Graph.width(graphPane.offsetWidth).height(graphPane.offsetHeight);
    };
    const onUp = () => {
      divider.classList.remove('dragging');
      document.removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseup', onUp);
    };
    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup', onUp);
  });

  // ── URL: initial load ──────────────────────────────────────────────────
  const initTopic = new URLSearchParams(window.location.search).get('topic');
  if (initTopic) {
    setTimeout(() => selectTopic(initTopic), 100);
  }
</script>
